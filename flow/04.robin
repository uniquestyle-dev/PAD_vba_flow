WebAutomation.LaunchChrome.LaunchChrome Url: $'''https://shop.localab.net/admin/''' WindowState: WebAutomation.BrowserWindowState.Maximized ClearCache: False ClearCookies: False WaitForPageToLoadTimeout: 60 Timeout: 60 BrowserInstance=> Browser
IF (WebAutomation.IfWebPageContains.WebPageContainsElement BrowserInstance: Browser Control: appmask['Web Page \'https://shop.localab.net/admin/\'']['Input text \'login_id\'']) THEN
    WAIT (WebAutomation.WaitForWebPageContent.WebPageToContainElement BrowserInstance: Browser Control: appmask['Web Page \'h ... c20ed1a96d\'']['Input text \'login_id\''])
    WebAutomation.PopulateTextField.PopulateTextField BrowserInstance: Browser Control: appmask['Web Page \'h ... e2f408a131\'']['Input text \'login_id\''] Text: $'''admin2245239899''' Mode: WebAutomation.PopulateTextMode.Replace EmulateTyping: False UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
    WebAutomation.PopulateTextField.PopulateTextField BrowserInstance: Browser Control: appmask['Web Page \'h ... e2f408a131\'']['Input password \'password\''] Text: P'' Mode: WebAutomation.PopulateTextMode.Replace EmulateTyping: False UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
    WAIT 2
    WebAutomation.PressButton.PressButton BrowserInstance: Browser Control: appmask['Web Page \'https://shop.localab.net/admin/\'']['Button \'ログイン\''] WaitForPageToLoadTimeout: 60
END
WAIT 2
WebAutomation.GoToWebPage.GoToWebPage BrowserInstance: Browser Url: $'''https://shop.localab.net/admin/customer/index.php''' WaitForPageToLoadTimeout: 60
DateTime.GetCurrentDateTime.Local DateTimeFormat: DateTime.DateTimeFormat.DateOnly CurrentDateTime=> CurrentDateTime
DateTime.Add DateTime: CurrentDateTime TimeToAdd: -1 TimeUnit: DateTime.TimeUnit.Days ResultedDate=> ResultedDate
Text.ConvertDateTimeToText.FromCustomDateTime DateTime: ResultedDate CustomFormat: $'''yyyy/MM/dd''' Result=> FormattedDateTime
WebAutomation.PopulateTextField.PopulateTextField BrowserInstance: Browser Control: appmask['Web Page \'h ... /index.php\'']['Input text \'create_start\''] Text: FormattedDateTime Mode: WebAutomation.PopulateTextMode.Replace EmulateTyping: False UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
WebAutomation.PopulateTextField.PopulateTextField BrowserInstance: Browser Control: appmask['Web Page \'h ... /index.php\'']['Input text \'create_end\''] Text: FormattedDateTime Mode: WebAutomation.PopulateTextMode.Replace EmulateTyping: False UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
WebAutomation.PopulateTextField.PopulateTextField BrowserInstance: Browser Control: appmask['Web Page \'h ... /index.php\'']['Input text \'buy_times_from\''] Text: 0 Mode: WebAutomation.PopulateTextMode.Replace EmulateTyping: False UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
WebAutomation.PopulateTextField.PopulateTextField BrowserInstance: Browser Control: appmask['Web Page \'h ... /index.php\'']['Input text \'buy_times_to\''] Text: 0 Mode: WebAutomation.PopulateTextMode.Replace EmulateTyping: False UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
WebAutomation.PressButton.PressButton BrowserInstance: Browser Control: appmask['Web Page \'h ... /index.php\'']['Button \'この条件で検索する\''] WaitForPageToLoadTimeout: 60
WebAutomation.ExtractData.ExtractHtmlTable BrowserInstance: Browser Control: $'''html > body > div:eq(0) > div:eq(0) > div > div:eq(0) > div > div > div:eq(1) > div:eq(2) > form > div:eq(2) > table''' ExtractionParameters: {[$'''顧客ID''', $'''顧客名/（カナ）''', $'''性別''', $'''TEL''', $'''所持ポイント''', $'''商品購入''', $'''削除'''], [$'''''', $'''''', $'''''', $'''''', $'''''', $'''''', $''''''] } PostProcessData: False TimeoutInSeconds: 60 ExtractedData=> OutputData
ON ERROR
    GOTO 'end'
END
SET CustomerIdExtraction TO 0
LOOP FOREACH CurrentItem IN OutputData
    Variables.IncreaseVariable Value: CustomerIdExtraction IncrementValue: 2
    WebAutomation.ExtractData.ExtractSingleValue BrowserInstance: Browser ExtractionParameters: {[$'''body > div:eq(0) > div:eq(0) > div > div:eq(0) > div > div > div:eq(1) > div:eq(2) > form > div:eq(2) > table > tbody > tr:eq(%CustomerIdExtraction%) > td:eq(0)''', $'''Own Text''', $''''''] } TimeoutInSeconds: 60 ExtractedData=> customerId
    ON ERROR
        GOTO 'end'
    END
    WebAutomation.Click.Click BrowserInstance: Browser Control: appmask['Web Page \'h ... /index.php\'']['Anchor \'別のタブで開く\''] ClickType: WebAutomation.ClickType.LeftClick MouseClick: True WaitForPageToLoadTimeout: 60 MousePositionRelativeToElement: WebAutomation.RectangleEdgePoint.MiddleCenter OffsetX: 0 OffsetY: 0
    WebAutomation.LaunchChrome.AttachToChromeByUrl TabUrl: $'''https://shop.localab.net/admin/customer/edit.php''' AttachTimeout: 5 BrowserInstance=> Browser2
    WebAutomation.GetDetailsOfElement BrowserInstance: Browser2 Control: appmask['Web Page \'https://shop.localab.net/admin/customer/edit.php\'']['Input text \'email\''] AttributeName: $'''innertext''' AttributeValue=> mail
    WebAutomation.CloseWebBrowser BrowserInstance: Browser2
    Email.SendEmail.AuthenticateAndSend SMTPServer: $'''whitelynx5.sakura.ne.jp''' Port: 587 EnableSSL: True Username: $'''shop@localab.net''' Password: P'' AcceptUntrustedCertificates: False SendFrom: $'''shop@localab.net''' SenderDisplayName: $'''ロカボ実験室ストア''' SendTo: mail BCC: $'''yonemori2@gmail.com''' Subject: $'''購入が完了しておりません(^-^;''' Body: $'''ロカボ実験室ストアをご利用いただき、

ありがとうございます。


先日ご紹介した商品の

お買い忘れは、ございませんか？


お忘れの場合は、下のページから再度ご注文ください。

▼もう一度注文する
https://shop.localab.net/product/list/9?adcd=pwhyjbhkago



※なお、すでにご購入済みの場合や、カートから削除済みの場合でも、本メールが送信されることがございますので、ご了承くださいませ。

============================

健康な日を、1日でも長く。
ロカボ実験室

info@shop.localab.net

============================''' IsBodyHtml: False
END
LABEL 'end'
WebAutomation.PressButton.PressButton BrowserInstance: Browser Control: appmask['Web Page \'https://shop.localab.net/admin/home.php\'']['Idiomatic text'] WaitForPageToLoadTimeout: 60
SET count TO (CustomerIdExtraction - 2) / 2
Email.SendEmail.AuthenticateAndSend SMTPServer: $'''whitelynx5.sakura.ne.jp''' Port: 587 EnableSSL: True Username: $'''shop@localab.net''' Password: P'' AcceptUntrustedCertificates: False SendFrom: $'''shop@localab.net''' SenderDisplayName: $'''【2-4】cカゴ落ちメール送信自動化''' SendTo: $'''yonemori2@gmail.com''' Subject: $'''カゴ落ちメール送信 %count% 件完了''' Body: $'''%FormattedDateTime% 分 %count% 件完了''' IsBodyHtml: False
WAIT 3
WebAutomation.CloseWebBrowser BrowserInstance: Browser
