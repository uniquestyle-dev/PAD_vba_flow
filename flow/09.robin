Scripting.RunVBScript.RunVBScript VBScriptCode: $'''WScript.Echo \"STEP 1\"

Dim latestFile, firstDate, rawDate
latestFile = \"%LatestFile.FullName%\"
rawDate = \"%FirstDate%\"
firstDate = Replace(rawDate, \" (ファイル)\", \"\")

WScript.Echo \"STEP 2: \" & latestFile
WScript.Echo \"STEP 3: \" & firstDate

\' ===== 今日のファイルかチェック ===== 
Dim fso, file, fileCreated
Set fso = CreateObject(\"Scripting.FileSystemObject\")

If fso.FileExists(latestFile) Then
    Set file = fso.GetFile(latestFile)
    fileCreated = DateValue(file.DateCreated)
    
    WScript.Echo \"ファイル作成日: \" & fileCreated
    WScript.Echo \"今日の日付: \" & Date
    
    If fileCreated <> Date Then
        WScript.Echo \"エラー: ファイルは今日作成されていません\"
        WScript.Quit(1)  \' エラーコードで終了
    End If
    
    WScript.Echo \"作成日チェックOK\"
Else
    WScript.Echo \"エラー: ファイルが見つかりません - \" & latestFile
    WScript.Quit(1)
End If

WScript.Echo \"STEP 4: Excel起動\"
