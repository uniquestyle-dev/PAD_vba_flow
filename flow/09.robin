DateTime.Add DateTime: CurrentDateTime2 TimeToAdd: -1 TimeUnit: DateTime.TimeUnit.Days ResultedDate=> YesterdayDate2
Text.ConvertDateTimeToText.FromCustomDateTime DateTime: YesterdayDate2 CustomFormat: $'''yyyy-MM-dd''' Result=> YesterdayString
Text.ConvertDateTimeToText.FromCustomDateTime DateTime: CurrentDateTime2 CustomFormat: $'''yyyy-MM-dd''' Result=> TodayString
Folder.GetFiles Folder: $'''C:\\Users\\lenovo\\Desktop\\ダウンロード''' FileFilter: $'''orders_export_1*.csv''' IncludeSubfolders: False FailOnAccessDenied: True SortBy1: Folder.SortBy.LastModified SortDescending1: True SortBy2: Folder.SortBy.NoSort SortDescending2: False SortBy3: Folder.SortBy.NoSort SortDescending3: False Files=> Files
SET LatestFile TO Files[0]
File.ReadFromCSVFile.ReadCSV CSVFile: Files[0] Encoding: File.CSVEncoding.UTF8 TrimFields: True FirstLineContainsColumnNames: True ColumnsSeparator: File.CSVColumnsSeparator.SystemDefault CSVTable=> CsvData
SET CountF07 TO 0
SET CountG07 TO 0
SET CountY07 TO 0
SET Count07b TO 0
SET CountCbrgl TO 0
SET CountCb03b TO 0
LOOP FOREACH CurrentRow IN CsvData
    IF Contains(CurrentRow['Created at'], TodayString, False) THEN
        NEXT LOOP
    END
    IF Contains(CurrentRow['Created at'], YesterdayString, False) THEN
        IF CurrentRow['Lineitem sku'] = $'''f07b''' THEN
            Variables.IncreaseVariable Value: CountF07 IncrementValue: 1
        END
        IF CurrentRow['Lineitem sku'] = $'''g07b''' THEN
            Variables.IncreaseVariable Value: CountG07 IncrementValue: 1
        END
        IF CurrentRow['Lineitem sku'] = $'''y07b''' THEN
            Variables.IncreaseVariable Value: CountY07 IncrementValue: 1
        END
        IF CurrentRow['Lineitem sku'] = $'''07b''' THEN
            Variables.IncreaseVariable Value: Count07b IncrementValue: 1
        END
        IF CurrentRow['Lineitem sku'] = $'''cbrgl''' THEN
            Variables.IncreaseVariable Value: CountCbrgl IncrementValue: 1
        END
        IF CurrentRow['Lineitem sku'] = $'''cb03b''' THEN
            Variables.IncreaseVariable Value: CountCb03b IncrementValue: 1
        END
    ELSE
        EXIT LOOP
    END
END
Text.ConvertDateTimeToText.FromCustomDateTime DateTime: CurrentDateTime2 CustomFormat: $'''yyyy/MM/dd''' Result=> TodayStringSlash
Text.ConvertDateTimeToText.FromCustomDateTime DateTime: YesterdayDate2 CustomFormat: $'''yyyy/MM/dd''' Result=> YesterdayStringSlash
Folder.GetFiles Folder: $'''C:\\Users\\lenovo\\Desktop\\ダウンロード''' FileFilter: $'''order_2*.csv''' IncludeSubfolders: False FailOnAccessDenied: True SortBy1: Folder.SortBy.LastModified SortDescending1: True SortBy2: Folder.SortBy.NoSort SortDescending2: False SortBy3: Folder.SortBy.NoSort SortDescending3: False Files=> Files
SET LatestFile TO Files[0]
File.ReadFromCSVFile.ReadCSV CSVFile: Files[0] Encoding: File.CSVEncoding.UTF8 TrimFields: True FirstLineContainsColumnNames: True ColumnsSeparator: File.CSVColumnsSeparator.SystemDefault CSVTable=> CsvData
LOOP FOREACH CurrentRow IN CsvData
    IF Contains(CurrentRow['オーダー日時'], TodayStringSlash, False) THEN
        NEXT LOOP
    END
    IF Contains(CurrentRow['オーダー日時'], YesterdayStringSlash, False) THEN
        IF CurrentRow['アイテム名'] = $'''【電子書籍】CARBOFF 7日限定価格f|''' THEN
            Variables.IncreaseVariable Value: CountF07 IncrementValue: 1
        END
        IF CurrentRow['アイテム名'] = $'''【電子書籍】CARBOFF 7日限定価格g''' THEN
            Variables.IncreaseVariable Value: CountG07 IncrementValue: 1
        END
        IF CurrentRow['アイテム名'] = $'''【電子書籍】CARBOFF 7日限定価格y|''' THEN
            Variables.IncreaseVariable Value: CountY07 IncrementValue: 1
        END
        IF CurrentRow['アイテム名'] = $'''【電子書籍】CARBOFF 7日限定価格s''' THEN
            Variables.IncreaseVariable Value: Count07b IncrementValue: 1
        END
        IF CurrentRow['アイテム名'] = $'''【電子書籍】CARBOFF''' THEN
            Variables.IncreaseVariable Value: CountCbrgl IncrementValue: 1
        END
        IF CurrentRow['アイテム名'] = $'''【電子書籍】CARBOFF 3日限定価格''' THEN
            Variables.IncreaseVariable Value: CountCb03b IncrementValue: 1
        END
    ELSE
        EXIT LOOP
    END
END
