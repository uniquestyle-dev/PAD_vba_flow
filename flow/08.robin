Web.DownloadFromWeb.DownloadToFile Url: $'''https://docs.google.com/spreadsheets/d/1Fz8joe3nmOhpNUd8Fm1dT6oTFjtst3PnorvR-uq1DFI/export?format=csv&gid=720883829''' FilePath: $'''C:\\Users\\lenovo\\Desktop\\ダウンロード\\pvuu.csv''' ConnectionTimeout: 30 FollowRedirection: True ClearCookies: False UserAgent: $'''Mozilla/5.0 (Windows; U; Windows NT 5.1; en-US; rv:1.8.1.21) Gecko/20100312 Firefox/3.6''' Encoding: Web.Encoding.AutoDetect AcceptUntrustedCertificates: False DownloadedFile=> DownloadedFile
File.ReadFromCSVFile.ReadCSV CSVFile: $'''C:\\Users\\lenovo\\Desktop\\ダウンロード\\pvuu.csv''' Encoding: File.CSVEncoding.UTF8 TrimFields: True FirstLineContainsColumnNames: False ColumnsSeparator: File.CSVColumnsSeparator.SystemDefault CSVTable=> CsvTable
Variables.CreateNewList List=> SessionList
Text.SplitText.Split Text: $'''/carboff2mv/ /carboff_g2/ /carboff_y2mv/ /carboff_p2/ /carboff_l2/''' StandardDelimiter: Text.StandardDelimiter.Space DelimiterTimes: 1 Result=> SearchKeywords
LOOP FOREACH CurrentKeyword IN SearchKeywords
    Variables.FilterDataTable DataTable: CsvTable FilterParameters: { ^['RULE', 'COLUMN', 'OPERATOR', 'VALUE'], [$'''''', 0, $'''Equal''', CurrentKeyword] } MatchCase: True FilteredDataTable=> MatcheRow
    Variables.ConvertDataTableToCSV.DataTableToCSVCommonSeparator DataTable: MatcheRow IncludeColumnNames: False ColumnsSeparator: Variables.CSVColumnsSeparator.SystemDefault CSVText=> MatcheRowAsText
    IF IsEmpty(MatcheRowAsText) THEN
        Variables.AddItemToList Item: 0 List: SessionList
        Variables.AddItemToList Item: 0 List: SessionList
    ELSE
        Variables.AddItemToList Item: MatcheRow[0][1] List: SessionList
        Variables.AddItemToList Item: MatcheRow[0][2] List: SessionList
    END
END
