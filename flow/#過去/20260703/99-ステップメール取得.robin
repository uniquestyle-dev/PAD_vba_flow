SET OutputDir TO $'''C:\\Users\\lenovo\\Desktop\\haihai_extract\\'''
SET BaseUrl TO $'''https://a12.hm-f.jp/QNvom3/index.php'''
WebAutomation.LaunchChrome.LaunchChrome Url: $'''https://a12.hm-f.jp/QNvom3/index.php''' WindowState: WebAutomation.BrowserWindowState.Normal ClearCache: False ClearCookies: False WaitForPageToLoadTimeout: 60 Timeout: 60 PiPUserDataFolderMode: WebAutomation.PiPUserDataFolderModeEnum.AutomaticProfile TargetDesktop: $'''{\"DisplayName\":\"ローカル コンピューター\",\"Route\":{\"ServerType\":\"Local\",\"ServerAddress\":\"\"},\"DesktopType\":\"local\"}''' BrowserInstance=> Browser
WebAutomation.PopulateTextField.PopulateTextField BrowserInstance: Browser Control: appmask['Web Page \'https://a12.hm-f.jp/QNvom3/index.php\'']['Input text \'loginid\''] Text: $'''toriaezu''' Mode: WebAutomation.PopulateTextMode.Replace EmulateTyping: False UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
WebAutomation.PopulateTextField.PopulateTextField BrowserInstance: Browser Control: appmask['Web Page \'https://a12.hm-f.jp/QNvom3/index.php\'']['Input password \'password\''] Text: P'' Mode: WebAutomation.PopulateTextMode.Replace EmulateTyping: False UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
WebAutomation.PressButton.PressButton BrowserInstance: Browser Control: appmask['Web Page \'https://a12.hm-f.jp/QNvom3/index.php\'']['Input submit \'ログイン\''] WaitForPageToLoadTimeout: 60
WebAutomation.GoToWebPage.GoToWebPage BrowserInstance: Browser Url: $'''%BaseUrl%?action=StepMailHome&columnid=2&offset=0&isasc=1''' WaitForPageToLoadTimeout: 60
WAIT 2
WebAutomation.SetDropDownListValue.SetDropDownListValueByName BrowserInstance: Browser Control: appmask['Web Page \'h ... =0&isasc=1\'']['Select \'10件\''] OptionNames: $'''50件''' UseRegularExpression: False WaitForPageToLoadTimeout: 60
WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.stringify(
    Array.from(document.querySelectorAll(\'tr\'))
      .filter(function(tr){ return tr.querySelector(\'a[href*=\"StepList\"]\'); })
      .map(function(tr){
        var link = tr.querySelector(\'a[href*=\"StepList\"]\');
        var spid = (link.href.match(/spid=(\\d+)/) || [])[1];
        var cells = tr.querySelectorAll(\'td\');
        var planName = cells[2] ? cells[2].textContent.trim() : \'\';
        var stepCount = parseInt(cells[7] ? cells[7].textContent.trim() : \'0\');
        var safeName = planName.replace(/\\//g,\'-\').replace(/\\[/g,\'(\').replace(/\\]/g,\')\').replace(/　/g,\' \').replace(/【/g,\'(\').replace(/】/g,\')\');
        return {spid: spid, planName: planName, safeName: safeName, stepCount: stepCount};
      })
  );
}''' Result=> PlansJson
WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() { return document.querySelectorAll(\'a[href*=\"StepList\"]\').length + \'\'; }''' Result=> PlanCountMax
Text.ToNumber Text: PlanCountMax Number=> PlanCountMax
SET P TO 0
LOOP WHILE (P) < (PlanCountMax)
    WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.parse(\'%PlansJson%\')[%P%].spid;
}''' Result=> CurrentSpid
    WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.parse(\'%PlansJson%\')[%P%].planName;
}''' Result=> CurrentPlanName
    WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.parse(\'%PlansJson%\')[%P%].safeName;
}''' Result=> CurrentSafeName
    SET OutputFile TO $'''%OutputDir%spid%CurrentSpid%_%CurrentSafeName%.tsv'''
    WebAutomation.GoToWebPage.GoToWebPage BrowserInstance: Browser Url: $'''%BaseUrl%?action=StepList&spid=%CurrentSpid%&offset=0''' WaitForPageToLoadTimeout: 60
    WAIT 5
    WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.stringify(
    Array.from(document.querySelectorAll(\'a[href*=\"ViewStep\"]\'))
      .map(function(a){ var m = a.href.match(/sid=(\\d+)/); return m ? m[1] : null; })
      .filter(function(x){ return x !== null; })
  );
}''' Result=> SidListJson
    WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.parse(\'%SidListJson%\').length + \'\';
}''' Result=> SidCountMax
    WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.stringify(
    Array.from(document.querySelectorAll(\'tr\'))
      .filter(function(tr){ var c=tr.querySelectorAll(\'td\'); return c.length>=9 && c[1].textContent.trim().match(/\\d+回目/); })
      .map(function(tr){ return tr.querySelectorAll(\'td\')[8].textContent.trim().replace(/\\s+/g,\'\'); })
  );
}''' Result=> IntervalsJson
    File.WriteText File: OutputFile TextToWrite: $'''ステップ番号|||件名|||本文|||配信間隔''' AppendNewLine: True IfFileExists: File.IfFileExists.Overwrite Encoding: File.FileEncoding.UTF8
    SET I TO 0
    LOOP WHILE (I) < (SidCountMax)
        WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.parse(\'%SidListJson%\')[%I%];
}''' Result=> CurrentSid
        WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return JSON.parse(\'%IntervalsJson%\')[%I%];
}''' Result=> CurrentInterval
        WebAutomation.GoToWebPage.GoToWebPage BrowserInstance: Browser Url: $'''%BaseUrl%?action=ViewStep&spid=%CurrentSpid%&sid=%CurrentSid%''' WaitForPageToLoadTimeout: 60
        WAIT 5
        WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  var m = document.body.innerText.match(/ステップ\\s*：\\s*(\\d+)\\s*回目/);
  return m ? m[1] : \'\';
}''' Result=> StepNum
        WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return document.getElementById(\'subject\').value;
}''' Result=> Subject
        WebAutomation.ExecuteJavascript BrowserInstance: Browser Javascript: $'''function() {
  return document.getElementById(\'viewBodyValue\').value;
}''' Result=> BodyRaw
        Text.Replace Text: BodyRaw TextToFind: $'''\\r\\n|\\r|\\n''' IsRegEx: True IgnoreCase: False ReplaceWith: $'''\\n''' ActivateEscapeSequences: False Result=> Body2
        SET TsvLine TO $'''%StepNum%|||%Subject%|||%Body2%|||%CurrentInterval%'''
        File.WriteText File: OutputFile TextToWrite: TsvLine AppendNewLine: True IfFileExists: File.IfFileExists.Append Encoding: File.FileEncoding.UTF8
        WAIT 2
        Variables.IncreaseVariable Value: I IncrementValue: 1
    END
    Variables.IncreaseVariable Value: P IncrementValue: 1
END
Display.ShowMessageDialog.ShowMessage Title: $'''全38プラン抽出完了''' Message: $'''全38プラン抽出完了''' Icon: Display.Icon.None Buttons: Display.Buttons.OK DefaultButton: Display.DefaultButton.Button1 IsTopMost: False ButtonPressed=> ButtonPressed

