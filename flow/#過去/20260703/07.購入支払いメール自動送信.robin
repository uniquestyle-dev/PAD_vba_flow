File.ReadFromCSVFile.ReadCSV CSVFile: Files2[0].Fullname Encoding: File.CSVEncoding.UTF8 TrimFields: True FirstLineContainsColumnNames: True ColumnsSeparator: File.CSVColumnsSeparator.SystemDefault CSVTable=> CSVTable
LOOP FOREACH CurrentMail IN RetrievedEmails
    Text.Replace.ReplaceTextWithRegex Text: CurrentMail.Subject TextToFind: $'''^.*オーダー番号[:：]\\s*(\\d+).*$''' IgnoreCase: False ReplaceWith: $'''$1''' ActivateEscapeSequences: False Result=> OrderNumber
    LOOP FOREACH CurrentRow IN CSVTable
        IF CurrentRow['オーダー番号'] = $'''#%OrderNumber%''' THEN
            Variables.CreateNewList List=> OrderArray
            Variables.AddItemToList Item: CurrentRow['オーダー番号'] List: OrderArray
            Variables.AddItemToList Item: CurrentRow['決済方法'] List: OrderArray
            Variables.AddItemToList Item: CurrentRow['オーダー日時'] List: OrderArray
            Variables.AddItemToList Item: CurrentRow['顧客名'] List: OrderArray
            Variables.AddItemToList Item: CurrentRow['メールアドレス'] List: OrderArray
            Variables.AddItemToList Item: CurrentRow['アイテム名'] List: OrderArray
            Variables.AddItemToList Item: CurrentRow['電話番号(購入者)'] List: OrderArray
        END
    END
    Email.SendEmail.AuthenticateAndSend SMTPServer: $'''smtp.gmail.com''' Port: 465 EnableSSL: True Username: $'''yonemori@localab.biz''' Password: pass AcceptUntrustedCertificates: False SendFrom: $'''yonemori@localab.biz''' SenderDisplayName: $'''ロカボ実験室-STORES購入''' SendTo: $''' stores@localab.net''' Subject: $'''【STORES】購入-%OrderArray[3]%''' Body: $'''━━━━━━━━━━━━━━━━━━
オーダー番号：%OrderArray[0]%
注文日：%OrderArray[2]%
お名前：%OrderArray[3]%
電話番号：%OrderArray[6]%
メールアドレス：%OrderArray[4]%
お支払い方法：%OrderArray[1]%

送信アカウント：stores@localab.net
━━━━━━━━━━━━━━━━━━



%CurrentMail.BodyText%''' IsBodyHtml: False
    Variables.IncreaseVariable Value: Count IncrementValue: 1
END
Email.RetrieveEmails.Retrieve IMAPServer: $'''imap.gmail.com''' Port: 993 EnableSSL: True Username: $'''yonemori@localab.biz''' Password: pass AcceptUntrustedCertificates: False MailFolder: $'''STORES通知''' MailsToRetrieve: Email.RetrieveMessagesMode.Unread MarkAsRead: True RetrievedEmails=> RetrievedEmails
Email.SendEmail.AuthenticateAndSend SMTPServer: $'''whitelynx5.sakura.ne.jp''' Port: 587 EnableSSL: True Username: $'''shop@localab.net''' Password: P'' AcceptUntrustedCertificates: False SendFrom: $'''shop@localab.net''' SenderDisplayName: $'''【2-7】STORES購入-完了''' SendTo: $'''yonemori2@gmail.com''' Subject: $'''【2-7】STORES購入送信 %Count% 件完了''' Body: $'''%Count% 件完了''' IsBodyHtml: False
